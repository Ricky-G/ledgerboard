{
  "name": "ledgerboard",
  "displayName": "LedgerBoard",
  "description": "Local-first Markdown Kanban with conflict-safe autosave, actionable validation, safe formatting repair, and append-only analytics.",
  "version": "0.2.0",
  "publisher": "ricky-g",
  "license": "MIT",
  "icon": "images/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/Ricky-G/ledgerboard.git"
  },
  "homepage": "https://github.com/Ricky-G/ledgerboard#readme",
  "bugs": {
    "url": "https://github.com/Ricky-G/ledgerboard/issues"
  },
  "engines": {
    "vscode": "^1.103.0"
  },
  "categories": ["Visualization", "Other"],
  "keywords": ["kanban", "markdown", "tasks", "project management", "local-first", "analytics", "git", "git-backed", "offline"],
  "galleryBanner": {
    "color": "#17202a",
    "theme": "dark"
  },
  "extensionKind": ["workspace"],
  "capabilities": {
    "untrustedWorkspaces": { "supported": true },
    "virtualWorkspaces": { "supported": true }
  },
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "ledgerBoard.openBoard",
        "title": "Open Board",
        "category": "LedgerBoard",
        "icon": "$(project)"
      },
      {
        "command": "ledgerBoard.initializeBoard",
        "title": "Initialize Board in Folder",
        "category": "LedgerBoard",
        "icon": "$(new-folder)"
      },
      {
        "command": "ledgerBoard.addOutcome",
        "title": "Add Outcome",
        "category": "LedgerBoard",
        "icon": "$(add)"
      },
      {
        "command": "ledgerBoard.validateBoard",
        "title": "Validate Board Bundle",
        "category": "LedgerBoard",
        "icon": "$(pass)"
      },
      {
        "command": "ledgerBoard.normalizeBoard",
        "title": "Normalize BOARD.md Formatting",
        "category": "LedgerBoard",
        "icon": "$(wand)"
      },
      {
        "command": "ledgerBoard.openStandard",
        "title": "Open Board Standard",
        "category": "LedgerBoard",
        "icon": "$(book)"
      }
    ],
    "walkthroughs": [
      {
        "id": "ledgerBoard.gettingStarted",
        "title": "Get started with LedgerBoard",
        "description": "Create a local-first Markdown board, open it visually, and validate its durable file contract.",
        "steps": [
          {
            "id": "ledgerBoard.initialize",
            "title": "Initialize the Markdown bundle",
            "description": "Run [Initialize Board in Folder](command:ledgerBoard.initializeBoard) to create only the missing board, configuration, and history files."
          },
          {
            "id": "ledgerBoard.open",
            "title": "Open the visual board",
            "description": "Run [Open Board](command:ledgerBoard.openBoard), then add and move outcomes while Markdown remains authoritative."
          },
          {
            "id": "ledgerBoard.validate",
            "title": "Validate and repair formatting",
            "description": "Run [Validate Board Bundle](command:ledgerBoard.validateBoard). Formatting-only issues can be repaired with [Normalize BOARD.md Formatting](command:ledgerBoard.normalizeBoard)."
          },
          {
            "id": "ledgerBoard.standard",
            "title": "Use the public board standard",
            "description": "Open the [Board Standard](command:ledgerBoard.openStandard) for the exact Markdown contract and coding-agent prompt."
          }
        ]
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "ledgerBoard.initializeBoard",
          "when": "explorerResourceIsFolder && resourceScheme == file",
          "group": "navigation@90"
        }
      ],
      "editor/title": [
        {
          "command": "ledgerBoard.validateBoard",
          "when": "resourceFilename == BOARD.md",
          "group": "navigation@80"
        },
        {
          "command": "ledgerBoard.normalizeBoard",
          "when": "resourceFilename == BOARD.md",
          "group": "navigation@81"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run privacy:scan && npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "privacy:scan": "node scripts/privacy-scan.js",
    "test": "npm run test:unit",
    "test:unit": "node --test test/*.test.js",
    "pretest:integration": "npm run compile-tests && npm run compile",
    "test:integration": "vscode-test",
    "validate:board": "node scripts/validate-board.js",
    "vsix": "vsce package --no-dependencies",
    "publish:marketplace": "vsce publish --no-dependencies"
  },
  "devDependencies": {
    "@types/vscode": "^1.103.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "24.x",
    "typescript-eslint": "^8.61.1",
    "eslint": "^10.5.0",
    "esbuild": "^0.28.1",
    "npm-run-all": "^4.1.5",
    "typescript": "^6.0.3",
    "@vscode/test-cli": "^0.0.15",
    "@vscode/test-electron": "^3.0.0",
    "@vscode/vsce": "^3.6.2"
  },
  "overrides": {
    "diff": "^8.0.4",
    "serialize-javascript": "^7.0.6"
  }
}
